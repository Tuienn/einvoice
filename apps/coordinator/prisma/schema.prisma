generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum ElectionStatus {
  PENDING
  ACTIVE
  CLOSED
  COMPLETED
}

model Election {
  id             String          @id @default(auto()) @map("_id") @db.ObjectId
  name           String          @unique
  status         ElectionStatus  @default(PENDING)
  candidateIds   String[]
  electionVoters ElectionVoter[]
  votes          Vote[]

  merkleRoot    String?
  blockchainRef String?

  collectivePublicKey String?

  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([status, startDate, endDate]) //lấy các election theo status trong khoảng thời gian
  @@map("elections")
}

model ElectionVoter {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  electionId String   @db.ObjectId
  election   Election @relation(fields: [electionId], references: [id])

  voterId String @db.ObjectId

  votes Vote[]

  @@unique([electionId, voterId]) //mỗi voter chỉ vote 1 lần cho 1 election
  @@index([voterId, electionId]) //lấy danh sách election của một voter
  @@map("election_voters")
}

model Vote {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  electionId String   @db.ObjectId
  election   Election @relation(fields: [electionId], references: [id])

  voterId String        @db.ObjectId
  voter   ElectionVoter @relation(fields: [voterId], references: [id])

  blindedCommitment String
  blockchainRef   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([electionId, voterId])
  @@index([electionId, createdAt]) //lấy votes của election X, sort theo thời gian tạo
  @@unique([electionId, blindedCommitment]) //đảm bảo không có 2 vote nào có blindedCommitment giống nhau trong cùng 1 election
  @@map("votes")
}

