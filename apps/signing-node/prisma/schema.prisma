// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// Lưu vĩnh viễn việc node đã ký cho cặp (electionId, voterId).
// Mỗi voter chỉ có thể được node này ký đúng 1 lần cho mỗi election.
// chống tích lũy nhiều hữ ký để reveal nhiều phiếu.
model SignedVoter {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  electionId String @db.ObjectId
  voterId    String @db.ObjectId

  sessionId String
  signedAt  DateTime @default(now())

  @@unique([electionId, voterId])
  @@map("signed_voters")
}

model KeyPair {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  electionId String @unique @db.ObjectId

  publicKey  String
  privateKey String

  createdAt DateTime @default(now())

  @@map("key_pairs")
}
