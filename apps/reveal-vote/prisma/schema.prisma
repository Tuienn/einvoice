generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}


type SignatureRevealedVote {
  h String
  sPrime String
}

model RevealedVote {
    id String @id @default(auto()) @map("_id") @db.ObjectId

    electionId String   @db.ObjectId 
    candidateId String @db.ObjectId

    revealKey String
    blockchainRef   String?
    signature SignatureRevealedVote
    revealedAt DateTime @default(now())

    @@index([electionId, candidateId]) //lấy revealed votes của election X, sort theo thời gian revealed
    @@unique([electionId, revealKey]) //mỗi vote chỉ được reveal 1 lần cho 1 election
    @@unique([electionId, signature.h, signature.sPrime]) //mỗi vote chỉ được reveal 1 lần cho 1 election
    @@map("revealed_votes")
}
